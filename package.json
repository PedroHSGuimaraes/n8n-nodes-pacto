{
  "name": "n8n-nodes-pacto",
  "version": "1.0.0",
  "description": "n8n community node for the Pacto Soluções API, with all official OpenAPI operations available through Area → Operation selection.",
  "keywords": [
    "n8n-community-node-package",
    "n8n",
    "pacto",
    "pacto solucoes",
    "academia",
    "fitness",
    "crm"
  ],
  "license": "MIT",
  "homepage": "https://github.com/PedroHSGuimaraes/n8n-nodes-pacto#readme",
  "author": {
    "name": "Pedro Henrique Santos Guimarães",
    "email": "pedro.guimaraes02@hotmail.com"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/PedroHSGuimaraes/n8n-nodes-pacto.git"
  },
  "bugs": {
    "url": "https://github.com/PedroHSGuimaraes/n8n-nodes-pacto/issues"
  },
  "main": "dist/nodes/Pacto/Pacto.node.js",
  "scripts": {
    "build": "tsc && gulp build:icons",
    "dev": "tsc --watch",
    "format": "prettier nodes credentials scripts --write",
    "lint": "eslint nodes credentials",
    "lintfix": "eslint nodes credentials --fix",
    "update:catalog": "node scripts/update-pacto-catalog.mjs",
    "prepublishOnly": "npm run build"
  },
  "files": [
    "dist"
  ],
  "n8n": {
    "n8nNodesApiVersion": 1,
    "credentials": [
      "dist/credentials/PactoApi.credentials.js"
    ],
    "nodes": [
      "dist/nodes/Pacto/Pacto.node.js"
    ]
  },
  "peerDependencies": {
    "n8n-workflow": "*"
  },
  "devDependencies": {
    "@n8n/eslint-plugin-community-nodes": "^0.23.0",
    "@types/node": "^18.19.0",
    "eslint": "^9.29.0",
    "gulp": "^4.0.2",
    "n8n-workflow": "^2.16.0",
    "prettier": "^3.3.0",
    "typescript": "^5.5.0",
    "typescript-eslint": "^8.63.0"
  }
}
